{
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "allowJs": true,
    "experimentalDecorators": true,
    "noEmitHelpers": true,
    "importHelpers": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["miniprogram-api-typings"]
  },
  "include": ["miniprogram/**/*.ts", "typings/**/*.d.ts"],
  "exclude": ["node_modules", "miniprogram/miniprogram_npm"]
}
