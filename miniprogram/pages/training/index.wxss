/**
 * 训练首页排版：大留白 + 轻量层次（对标 Apple Fitness / Notion 的克制感）。
 */

.page--training {
  box-sizing: border-box;
}

.training-page__content {
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
}

.training-page__hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.training-page__hero-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

.training-page__hero-title {
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.15;
  color: var(--text-primary);
  letter-spacing: 0.5rpx;
}

.training-page__hero-sub {
  font-size: 28rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  max-width: 620rpx;
}

.training-stats__cell {
  flex: 1;
  min-width: 0;
}
