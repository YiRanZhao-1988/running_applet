<!--
  训练 Tab：文案与数据均来自 store 绑定字段。
-->
<view class="u-tab-page page--training">
  <scroll-view class="u-tab-page__scroll" scroll-y>
    <view class="u-px-page training-page__content">
      <view class="training-page__hero u-mb-lg">
        <text class="training-page__hero-kicker">{{trainingHero.kicker}}</text>
        <text class="training-page__hero-title">{{trainingHero.title}}</text>
        <text class="training-page__hero-sub">{{trainingHero.subtitle}}</text>
      </view>

      <view class="u-mb-lg">
        <motivation-banner messages="{{motivationLines}}" interval-ms="{{12000}}" />
      </view>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="{{trainingSections.week}}" />
        </view>
        <week-calendar
          days="{{weekDays}}"
          week-range-text="{{weekRangeText}}"
          bind:prev="calendarWeekPrev"
          bind:next="calendarWeekNext"
          bind:selectday="onSelectDay"
        />
      </ui-section>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="{{trainingSections.today}}" />
        </view>
        <training-card session="{{todaySession}}" />
      </ui-section>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="{{trainingSections.stats}}" />
        </view>
        <view class="training-stats u-row u-row-gap-md">
          <ui-stat-block
            wx:for="{{stats}}"
            wx:key="label"
            ext-class="training-stats__cell"
            label="{{item.label}}"
            value="{{item.value}}"
          />
        </view>
      </ui-section>

      <view class="u-py-xl" />
    </view>
  </scroll-view>
</view>
