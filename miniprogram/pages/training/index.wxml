<!--
  训练 Tab：任务执行导向布局 — 激励语 / 周日历 / 今日课表 / 统计。
-->
<view class="u-tab-page page--training">
  <scroll-view class="u-tab-page__scroll" scroll-y>
    <view class="u-px-page training-page__content">
      <view class="training-page__hero u-mb-lg">
        <text class="training-page__hero-kicker">Today</text>
        <text class="training-page__hero-title">执行今天的训练</text>
        <text class="training-page__hero-sub">
          一次只专注一件事：完成课表，然后把它放下。
        </text>
      </view>

      <view class="u-mb-lg">
        <motivation-banner messages="{{motivationLines}}" interval-ms="{{12000}}" />
      </view>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="本周" />
        </view>
        <week-calendar
          days="{{weekDays}}"
          week-range-text="{{weekRangeText}}"
          bind:prev="onWeekPrev"
          bind:next="onWeekNext"
          bind:selectday="onSelectDay"
        />
      </ui-section>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="今日课表" />
        </view>
        <training-card session="{{todaySession}}" />
      </ui-section>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="训练统计" />
        </view>
        <view class="training-stats u-row u-row-gap-md">
          <ui-stat-block
            wx:for="{{stats}}"
            wx:key="label"
            ext-class="training-stats__cell"
            label="{{item.label}}"
            value="{{item.value}}"
          />
        </view>
      </ui-section>

      <view class="u-py-xl" />
    </view>
  </scroll-view>
</view>
