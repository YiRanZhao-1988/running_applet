/**
 * 登录页：低饱和、沉浸式；背景为三色意境渐变缓慢轮替 + 轻呼吸缩放（无粒子）。
 */
.login {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
  color: rgba(250, 250, 250, 0.92);
}

.login__bg {
  position: absolute;
  inset: -12%;
  z-index: 0;
}

.login__bg-layer {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: scale(1.04);
  will-change: opacity, transform;
  animation: login-scene-cycle 24s ease-in-out infinite;
}

/* 清晨城市：冷灰与极弱暖边光 */
.login__bg-layer--dawn {
  background: linear-gradient(
    168deg,
    #2a3038 0%,
    #3d4550 38%,
    #5c636c 72%,
    #8b9098 100%
  );
  animation-delay: 0s;
}

/* 夜跑：深蓝灰，略沉 */
.login__bg-layer--night {
  background: linear-gradient(
    192deg,
    #161820 0%,
    #222633 45%,
    #353849 100%
  );
  animation-delay: -8s;
}

/* 空旷道路：中性灰褐，像路面与雾 */
.login__bg-layer--road {
  background: linear-gradient(
    178deg,
    #252628 0%,
    #3a3d42 42%,
    #5e6368 100%
  );
  animation-delay: -16s;
}

@keyframes login-scene-cycle {
  0% {
    opacity: 0;
    transform: scale(1.03);
  }
  8% {
    opacity: 0.85;
    transform: scale(1.06);
  }
  33% {
    opacity: 0.85;
    transform: scale(1.04);
  }
  41% {
    opacity: 0;
    transform: scale(1.03);
  }
  100% {
    opacity: 0;
    transform: scale(1.03);
  }
}

/* 弱雾面，压低对比、略柔化 */
.login__bg-veil {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 120% 80% at 50% 100%,
    rgba(255, 255, 255, 0.07),
    transparent 55%
  );
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.login__content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 56rpx;
  box-sizing: border-box;
}

.login__center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 10vh;
}

/* 几何 Logo：细环 + 横线，克制符号感 */
.login__mark {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 40rpx;
}

.login__mark-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  box-sizing: border-box;
}

.login__mark-line {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 1rpx;
  margin-left: -14rpx;
  margin-top: -1rpx;
  background: rgba(255, 255, 255, 0.45);
}

.login__wordmark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.login__wordmark-line {
  font-size: 56rpx;
  font-weight: 300;
  letter-spacing: 0.35em;
  line-height: 1.15;
  color: rgba(252, 252, 252, 0.96);
}

.login__slogan {
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 0.14em;
  color: rgba(230, 232, 235, 0.62);
}

.login__footer {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.login__quote {
  min-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 32rpx 0;
  box-sizing: content-box;
}

.login__quote-text {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.65;
  text-align: center;
  letter-spacing: 0.08em;
  color: rgba(220, 223, 228, 0.75);
  transition: opacity 0.45s ease;
}

.login__btn {
  width: 100%;
  max-width: 520rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  margin: 0;
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.96);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 0.12em;
}

.login__btn::after {
  border: none;
}

.login__btn[disabled] {
  opacity: 0.55;
}

.login__btn--hover {
  background: rgba(255, 255, 255, 0.16);
  border-color: rgba(255, 255, 255, 0.28);
}
