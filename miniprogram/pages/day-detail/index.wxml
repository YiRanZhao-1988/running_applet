<view class="u-tab-page page--day-detail">
  <scroll-view class="u-tab-page__scroll" scroll-y>
    <view class="u-px-page day-detail" wx:if="{{hasContent}}">
      <view class="day-detail__hero">
        <text class="day-detail__kicker">{{detailCopy.kicker}}</text>
        <text class="day-detail__date-line">{{dateHeaderLine}}</text>
        <text class="day-detail__type">{{dayTypeLabel}}</text>
      </view>

      <view class="day-detail__section-head">
        <text class="day-detail__section-title">{{detailCopy.sectionTitle}}</text>
        <text class="day-detail__section-sub">{{detailCopy.sectionSub}}</text>
      </view>

      <view class="day-detail__list">
        <todo-training-card
          wx:for="{{todos}}"
          wx:key="id"
          todo="{{item}}"
          bind:toggle="onTodoToggle"
        />
      </view>

      <view class="u-py-xl" />
    </view>

    <view class="u-px-page day-detail day-detail--empty u-py-xl" wx:else>
      <text class="day-detail__empty">未携带有效日期参数。请从训练页周历进入。</text>
    </view>
  </scroll-view>

  <view class="fb-mask" wx:if="{{showFeedback}}" catchtap="closeFeedbackModal">
    <view class="fb-sheet" catchtap="onSheetTouch">
      <text class="fb-title">{{detailCopy.feedbackTitle}}</text>
      <text class="fb-desc">{{detailCopy.feedbackDesc}}</text>

      <view class="fb-options">
        <view
          wx:for="{{feedbackOptions}}"
          wx:key="key"
          class="fb-option"
          data-feedback-key="{{item.key}}"
          hover-class="fb-option--hover"
          hover-stay-time="60"
          bindtap="onFeedbackSelect"
        >
          <text class="fb-option__text">{{item.label}}</text>
        </view>
      </view>

      <view class="fb-later" hover-class="fb-later--hover" hover-stay-time="60" bindtap="closeFeedbackModal">
        <text class="fb-later__text">{{detailCopy.laterLabel}}</text>
      </view>
    </view>
  </view>
</view>
