<!--
  AI 计划 Tab：标题与入口列表来自 aiPlanPage（mock）。
-->
<view class="u-tab-page page--ai-plan">
  <scroll-view class="u-tab-page__scroll" scroll-y>
    <view class="u-px-page u-py-lg u-stack-md">
      <view>
        <ui-title variant="page" text="{{aiPage.title}}" />
        <view class="u-subtitle">{{aiPage.subtitle}}</view>
      </view>

      <ui-action-entry
        wx:for="{{aiPage.entries}}"
        wx:key="id"
        title="{{item.title}}"
        description="{{item.description}}"
      />

      <view class="u-mt-sm">
        <view class="u-btn u-btn--primary u-btn--block">{{aiPage.primaryCta}}</view>
      </view>

      <view class="u-py-lg" />
    </view>
  </scroll-view>
</view>
