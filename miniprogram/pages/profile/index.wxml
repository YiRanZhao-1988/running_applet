<!--
  我的 Tab：文案来自 profilePage mock，统计来自 store 派生。
-->
<view class="u-tab-page page--profile">
  <scroll-view class="u-tab-page__scroll" scroll-y>
    <view class="u-px-page u-py-lg u-stack-md">
      <ui-card>
        <view class="profile-header u-row u-row-gap-md">
          <view class="profile-header__avatar" />
          <view class="profile-header__meta">
            <ui-title variant="card" text="{{profilePage.user.title}}" />
            <view class="u-subtitle">{{profilePage.user.subtitle}}</view>
          </view>
        </view>
      </ui-card>

      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="{{profilePage.overviewTitle}}" />
        </view>
        <view class="profile-metrics u-row u-row-gap-md">
          <ui-stat-block
            wx:for="{{profileStats}}"
            wx:key="id"
            ext-class="profile-metrics__cell"
            label="{{item.label}}"
            value="{{item.value}}"
          />
        </view>
      </ui-section>

      <ui-action-entry
        title="{{profilePage.historyEntry.title}}"
        description="{{profilePage.historyEntry.description}}"
      />

      <ui-card>
        <ui-title variant="section" text="{{profilePage.settings.title}}" />
        <view class="u-mt-sm">
          <ui-action-entry
            wx:for="{{profileSettingRows}}"
            wx:key="id"
            elevated="{{false}}"
            title="{{item.title}}"
            description="{{item.description}}"
            isLast="{{item.isLast}}"
          />
        </view>
      </ui-card>

      <view class="u-py-lg" />
    </view>
  </scroll-view>
</view>
