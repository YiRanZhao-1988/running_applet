<!--
  我的 Tab：用户信息 / 数据概览 / 历史入口 / 设置分组；无登录态校验与跳转。
-->
<view class="u-tab-page page--profile">
  <scroll-view class="u-tab-page__scroll" scroll-y>
    <view class="u-px-page u-py-lg u-stack-md">
      <!-- 用户信息 -->
      <ui-card>
        <view class="profile-header u-row u-row-gap-md">
          <view class="profile-header__avatar" />
          <view class="profile-header__meta">
            <ui-title variant="card" text="账号" />
            <view class="u-subtitle">登录后同步计划进度与历史记录（占位说明）</view>
          </view>
        </view>
      </ui-card>

      <!-- 数据统计 -->
      <ui-section showHeader="{{true}}">
        <view slot="header">
          <ui-title variant="section" text="数据概览" />
        </view>
        <view class="profile-metrics u-row u-row-gap-md">
          <ui-stat-block ext-class="profile-metrics__cell" label="总跑量" />
          <ui-stat-block ext-class="profile-metrics__cell" label="计划完成率" />
        </view>
      </ui-section>

      <!-- 历史训练 -->
      <ui-action-entry title="历史训练" description="按时间查看已完成与错过的训练安排" />

      <!-- 设置 -->
      <ui-card>
        <ui-title variant="section" text="设置" />
        <view class="u-mt-sm">
          <ui-action-entry elevated="{{false}}" title="通知" description="训练提醒与计划变更（占位）" />
          <ui-action-entry elevated="{{false}}" title="隐私与数据" description="本地与云同步策略（占位）" />
          <ui-action-entry elevated="{{false}}" title="关于" description="版本与协议入口（占位）" isLast="{{true}}" />
        </view>
      </ui-card>

      <view class="u-py-lg" />
    </view>
  </scroll-view>
</view>
